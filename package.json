{
  "name": "obsidian-thoth",
  "version": "0.4.22",
  "description": "Lightweight vault sync via S3-compatible object storage",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --external:obsidian --outfile=main.js --format=cjs --platform=browser --sourcemap --watch",
    "build": "esbuild src/main.ts --bundle --external:obsidian --outfile=main.js --format=cjs --platform=browser --minify",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "obsidian": "^1.5.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "diff-match-patch": "^1.0.5",
    "qrcode-generator": "^2.0.4"
  }
}
